APP_NAME="JBLU Office"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=office
DB_USERNAME=jblu
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
OFFICE_DOCUMENT_DISK=documents
OFFICE_CHROME_BINARY=
OFFICE_PDF_TIMEOUT=120
QUEUE_CONNECTION=database
DB_QUEUE=default
PDF_QUEUE_CONNECTION=database
PDF_QUEUE=pdf
QUEUE_AFTER_COMMIT=true
OFFICE_BUSINESS_TIMEZONE=Asia/Jakarta
OFFICE_QUOTATION_DOCUMENT_TYPE_CODE=QUOTATION

# Evidence JSON diterbitkan oleh backup/restore system; gunakan absolute path di production.
OFFICE_BACKUP_EVIDENCE_PATH=
OFFICE_RESTORE_EVIDENCE_PATH=
OFFICE_UAT_EVIDENCE_PATH=
OFFICE_CUTOVER_MANIFEST_PATH=
OFFICE_DATABASE_BACKUP_MAX_AGE_HOURS=26
OFFICE_WAL_ARCHIVE_MAX_AGE_MINUTES=60
OFFICE_PRIVATE_FILES_BACKUP_MAX_AGE_MINUTES=60
OFFICE_RESTORE_DRILL_MAX_AGE_DAYS=93
OFFICE_QUEUE_PENDING_ALERT=100
OFFICE_QUEUE_FAILED_ALERT=1

OFFICE_SSO_BASE_URL=
OFFICE_SSO_CLIENT_ID=
OFFICE_SSO_CLIENT_SECRET=
OFFICE_SSO_REDIRECT_URI="${APP_URL}/auth/callback"
OFFICE_SSO_SCOPES="openid profile email"
OFFICE_SSO_TENANT_ID=
OFFICE_SSO_SESSION_MAX_MINUTES=480

OFFICE_BOOTSTRAP_ADMIN_SSO_ISSUER=
OFFICE_BOOTSTRAP_ADMIN_SSO_SUBJECT=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
